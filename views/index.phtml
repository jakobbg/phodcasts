<script>
function copyRssFeed(btn, url) {
  var SVG_COPY  = btn.innerHTML;
  var SVG_CHECK = '<svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>';
  if (!navigator.clipboard) { prompt('Copy this feed URL:', url); return; }
  navigator.clipboard.writeText(url).then(function () {
    btn.innerHTML = SVG_CHECK;
    btn.classList.add('copied');
    setTimeout(function () { btn.innerHTML = SVG_COPY; btn.classList.remove('copied'); }, 2000);
  });
}
function copyFeed(btn, url) {
  if (!navigator.clipboard) { prompt('Copy this feed URL:', url); return; }
  navigator.clipboard.writeText(url).then(function () {
    var orig = btn.textContent, origLabel = btn.getAttribute('aria-label');
    btn.style.width = btn.offsetWidth + 'px';
    btn.textContent = 'Copied!';
    btn.setAttribute('aria-label', 'Copied to clipboard');
    setTimeout(function () { btn.style.width = ''; btn.textContent = orig; btn.setAttribute('aria-label', origLabel); }, 2000);
  });
}
(function () {
  // Copy GitHub commit URL when the app title is clicked.
  var titleEl = document.getElementById('app-title');
  if (titleEl) {
    titleEl.addEventListener('click', function () {
      var url = '<?= h($commitUrl) ?>';
      if (!url) return;
      if (!navigator.clipboard) { prompt('Commit URL:', url); return; }
      navigator.clipboard.writeText(url).then(function () {
        var brand = document.getElementById('app-brand');
        var origText  = brand ? brand.textContent : '';
        var origTitle = titleEl.getAttribute('title');
        if (brand) brand.textContent = 'Copied!';
        setTimeout(function () {
          if (brand) brand.textContent = origText;
          titleEl.setAttribute('title', origTitle);
        }, 2000);
      });
    });
  }
}());
(function () {
  var inp = document.getElementById('feed-search');
  if (!inp) return;
  function filterCards(q) {
    q = q.toLowerCase().trim();
    document.querySelectorAll('.grid section.card').forEach(function (card) {
      var h2 = card.querySelector('h2');
      var title = h2 ? h2.textContent.toLowerCase() : '';
      card.style.display = (!q || title.indexOf(q) !== -1) ? '' : 'none';
    });
  }
  inp.addEventListener('input', function () { filterCards(inp.value); });
  if (inp.value) filterCards(inp.value);
}());
// Remember current page URL so the show detail page can navigate back here.
(function () {
  document.querySelectorAll('a.btn[href*="/show/"]').forEach(function (a) {
    a.addEventListener('click', function () {
      sessionStorage.setItem('ph-back', window.location.href);
    });
  });
}());
</script>
</body>
</html>
