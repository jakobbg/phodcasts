          <linearGradient id="ph-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%"   stop-color="hsl(<?= $phHue ?>,55%,30%)"/>
            <stop offset="100%" stop-color="hsl(<?= $phHue2 ?>,50%,20%)"/>
          </linearGradient>
        </defs>
        <rect width="180" height="180" fill="url(#ph-grad)"/>
        <text x="90" y="90" dominant-baseline="central" text-anchor="middle"
              font-family="ui-sans-serif,system-ui,-apple-system,sans-serif"
              font-size="<?= mb_strlen($phInit) > 1 ? '68' : '82' ?>" font-weight="700"
