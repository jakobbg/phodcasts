<?php if (!empty($coverUrls)): ?>
(function () {
  var images = <?= json_encode(array_values($coverUrls), JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) ?>;
  if (!Array.isArray(images) || images.length < 2) return;
  var img = document.getElementById('show-cover-image');
  var prev = document.getElementById('cover-prev');
  var next = document.getElementById('cover-next');
  if (!img || !prev || !next) return;

  var idx = 0;
  function showAt(nextIdx) {
    idx = (nextIdx + images.length) % images.length;
    img.src = images[idx];
  }

  prev.addEventListener('click', function () { showAt(idx - 1); });
  next.addEventListener('click', function () { showAt(idx + 1); });
}());
