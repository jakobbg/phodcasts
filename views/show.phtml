      if (count($phSig) >= 2)
          $phInit = mb_strtoupper(mb_substr($phSig[0], 0, 1) . mb_substr($phSig[1], 0, 1));
      elseif (count($phSig) === 1)
          $phInit = mb_strtoupper(mb_substr($phSig[0], 0, 2));
      else
          $phInit = mb_strtoupper(mb_substr($displayTitle, 0, 2));
      $phHue  = abs(crc32($displayTitle)) % 360;
      $phHue2 = ($phHue + 40) % 360;
    ?>
      <svg class="cover cover-placeholder" viewBox="0 0 180 180" xmlns="http://www.w3.org/2000/svg"
           role="img" aria-label="No cover art for <?= h($name) ?>">
